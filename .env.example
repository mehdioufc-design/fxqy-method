# Local web address. Keep this exact and include the port.
APP_ORIGIN=http://127.0.0.1:3000
APP_HOST=127.0.0.1
APP_PORT=3000
ALLOW_NETWORK_BIND=false
ALLOW_INSECURE_HTTP=false
TRUST_PROXY=false
# ALLOWED_HOSTS=127.0.0.1:3000
# For a public deployment, use your real HTTPS origin and host:
# APP_ORIGIN=https://optimizer.example.com
# APP_HOST=0.0.0.0
# ALLOW_NETWORK_BIND=true
# TRUST_PROXY=true
# ALLOWED_HOSTS=optimizer.example.com

# All media stays below this local directory.
DATA_ROOT=.data
# Bundled binaries are used by default. Set these only to override them.
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
# FFPROBE_PATH=C:\ffmpeg\bin\ffprobe.exe
MAX_UPLOAD_BYTES=2147483648
MIN_FREE_BYTES=5368709120
RETENTION_HOURS=168
JOB_TIMEOUT_MINUTES=360
PROCESS_CONCURRENCY=1

NEXT_TELEMETRY_DISABLED=1
